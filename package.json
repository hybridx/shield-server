{
  "name": "shield-server",
  "version": "2.0.1",
  "description": "Express middlewares bundle to bootstrap a backend project in minutes",
  "bin": "./dist/bin/shield-server.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">= 18.0.0"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "prebuild": "npm run clean && npm run lint",
    "dev": "ts-node ./src/bin/shield-server.ts",
    "build": "tsc --build tsconfig.production.json",
    "pretest": "npm run lint",
    "test": "mocha",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf ./dist ./coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hybridx/shield-server.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hybridx/shield-server/issues"
  },
  "homepage": "https://github.com/hybridx/shield-server#readme",
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/connect-history-api-fallback": "^1.5.4",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/figlet": "^1.7.0",
    "@types/lodash": "^4.17.13",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.0",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "arg": "^5.0.2",
    "chalk": "^4.1.2",
    "compression": "^1.7.5",
    "connect-history-api-fallback": "^2.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cosmiconfig": "^9.0.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "figlet": "^1.8.0",
    "helmet": "^8.0.0",
    "http-proxy-middleware": "^3.0.3",
    "internal-ip": "^7.0.0",
    "lodash": "^4.17.21",
    "morgan": "^1.10.0"
  }
}
